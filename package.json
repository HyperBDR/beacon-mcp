{
  "name": "@beacon/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the beacon log analytics platform \u2014 exposes the beacon REST API as MCP tools/resources so AI agents can query and analyze AI assistant usage data.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.17.0"
  },
  "bin": {
    "beacon-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ofetch": "^1.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "msw": "^2.6.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "beacon",
    "ai-agent",
    "analytics"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HyperBDR/beacon-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/HyperBDR/beacon-mcp/issues"
  },
  "homepage": "https://github.com/HyperBDR/beacon-mcp#readme"
}
