# Beacon REST API base URL
BEACON_BASE_URL=http://127.0.0.1:8080

# Default organization (tenant) ID. Must match an ID from /api/v1/orgs.
# Tools can override this with the `org` argument.
BEACON_ORG=default

# Request timeout in milliseconds (default 30000)
BEACON_TIMEOUT_MS=30000

# Optional API key (sent as `Authorization: Bearer <key>` if set)
# BEACON_API_KEY=

# HTTP transport settings (only used with --http)
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765
